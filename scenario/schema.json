{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://crisis-mars.app/schemas/scenario.schema.json",
  "title": "Crisis: Mars scenario",
  "description": "Static, version-pinned definition of a Crisis: Mars scenario. Loaded by the seed script into the `scenario`, `faction`, `role`, `map`, `map_score_track`, `map_location`, and `card_template` tables. Game-session state (current scores, hands, etc.) is NOT in this file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "default_player_count_min",
    "default_player_count_max",
    "schedule",
    "factions",
    "roles",
    "npcs",
    "maps",
    "card_templates",
    "war_correspondence"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "default_player_count_min": { "type": "integer", "minimum": 1 },
    "default_player_count_max": { "type": "integer", "minimum": 1 },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intro", "locations", "factions_overview"],
      "properties": {
        "intro": { "type": "string" },
        "locations": { "type": "string" },
        "factions_overview": { "type": "string" }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prologue_seconds", "turns", "epilogue_seconds"],
      "properties": {
        "prologue_seconds": { "type": "integer", "minimum": 0 },
        "epilogue_seconds": { "type": "integer", "minimum": 0 },
        "turns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["number", "team_seconds", "negotiation_seconds", "action_seconds"],
            "properties": {
              "number": { "type": "integer", "minimum": 1 },
              "team_seconds": { "type": "integer", "minimum": 0 },
              "negotiation_seconds": { "type": "integer", "minimum": 0 },
              "action_seconds": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "factions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "short_name", "colour", "public_brief", "common_goals", "sort_order"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "short_name": { "type": "string" },
          "colour": { "type": "string" },
          "icon_url": { "type": "string" },
          "icon_small_url": { "type": "string" },
          "icon_colour_url": { "type": "string" },
          "public_brief": { "type": "string" },
          "common_goals": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "sort_order": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "name",
          "faction_id",
          "public_description",
          "private_brief",
          "personal_goal",
          "initiative_by_turn",
          "availability",
          "sort_order"
        ],
        "properties": {
          "code": { "type": "string", "pattern": "^[A-Z][0-9]+$" },
          "name": { "type": "string" },
          "faction_id": { "type": "string" },
          "public_description": { "type": "string" },
          "private_brief": { "type": "string" },
          "personal_goal": { "type": "string" },
          "initiative_by_turn": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1 },
            "description": "Initiative number per turn (index 0 = turn 1). Lower = earlier action."
          },
          "availability": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["player_count", "is_recommended"],
              "properties": {
                "player_count": { "type": "integer", "minimum": 1 },
                "is_recommended": { "type": "boolean" }
              }
            }
          },
          "sort_order": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "npcs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "name", "default_controller", "public_description", "facilitator_notes"],
        "properties": {
          "code": { "type": "string", "pattern": "^N[0-9]+$" },
          "name": { "type": "string" },
          "default_controller": {
            "type": "string",
            "enum": ["earth_control", "mars_control", "belt_control"]
          },
          "public_description": { "type": "string" },
          "facilitator_notes": { "type": "string" }
        }
      }
    },
    "maps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "sort_order", "score_tracks", "locations"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "image_url": { "type": "string" },
          "sort_order": { "type": "integer", "minimum": 0 },
          "score_tracks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "min_value", "max_value", "starting_value", "visible_to_players", "sort_order"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "min_value": { "type": "integer" },
                "max_value": { "type": "integer" },
                "starting_value": { "type": "integer" },
                "visible_to_players": { "type": "boolean" },
                "shared_with_map_ids": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "sort_order": { "type": "integer" }
              }
            }
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "valid_for_actions", "sort_order"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "valid_for_actions": { "type": "boolean" },
                "sort_order": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "card_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "card_type", "name", "tradeable", "reclaimable"],
        "properties": {
          "id": { "type": "string" },
          "card_type": { "type": "string", "enum": ["action", "resource"] },
          "name": { "type": "string" },
          "faction_id": { "type": ["string", "null"] },
          "owner_role_code": {
            "type": ["string", "null"],
            "description": "Role code (e.g. C1) this template starts in. For action cards this is the only owner; for resource cards multiple instances can share an owner_role_code via starting_distribution."
          },
          "rules_text": { "type": "string" },
          "flavour_text": { "type": "string" },
          "impact_bonus": { "type": "integer" },
          "tradeable": { "type": "boolean" },
          "reclaimable": { "type": "boolean" }
        }
      }
    },
    "starting_resource_distribution": {
      "type": "array",
      "description": "How many physical resource-card instances each role starts with for each resource template.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role_code", "resource_template_id", "count"],
        "properties": {
          "role_code": { "type": "string" },
          "resource_template_id": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "war_correspondence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["turn", "title", "public_text"],
        "properties": {
          "turn": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "public_text": { "type": "string" },
          "facilitator_notes": { "type": "string" },
          "suggested_effects": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["description"],
              "properties": {
                "description": { "type": "string" },
                "score_track_id": { "type": "string" },
                "delta": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
