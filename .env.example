# Supabase project URL (e.g. https://abcdefghij.supabase.co)
PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Safe to ship in client builds.
PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Used ONLY by scripts/seed-from-scenario.mjs against a local
# Supabase instance. NEVER commit, NEVER ship to clients.
SUPABASE_SERVICE_ROLE_KEY=
